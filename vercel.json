{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 30
    }
  },
  "env": {
    "DATABASE_PATH": "/tmp/market_board.sqlite3",
    "WATCHLIST_PATH": "/tmp/watchlists.yaml",
    "WATCHLIST_SEED_PATH": "./config/watchlists.yaml",
    "ENABLE_BACKGROUND_TASKS": "false",
    "QUOTE_POLL_SECONDS": "15"
  }
}
